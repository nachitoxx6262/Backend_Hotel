# ============================================================
# HOTEL MANAGEMENT SYSTEM - Variables de entorno requeridas
# Copiar a .env y completar con los valores reales
# ============================================================

# --- Entorno ---
ENV=development           # development | production
DEBUG=false

# --- Base de datos PostgreSQL ---
DB_USER=hotel_user
DB_PASSWORD=cambiar_esto
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_db

# Pool de conexiones (opcional, valores por defecto razonables)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Seguridad JWT ---
# OBLIGATORIO en producción: generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=cambiar_esto_por_clave_segura_de_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Stripe (pagos) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute

# --- Redis (opcional, para rate limiting en producción) ---
# Si no se configura, usa memoria en proceso (no apto para múltiples instancias)
# REDIS_URL=redis://localhost:6379/0

# --- Email SMTP ---
# Usar SMTP de Gmail, Mailgun, Resend, etc.
# Para Gmail: habilitar "App Passwords" en la cuenta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
SMTP_FROM=noreply@tuhotel.com

# --- Cifrado Fernet (contraseñas SMTP guardadas en DB) ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Mercado Pago (mercado argentino) ---
# Obtener en https://www.mercadopago.com.ar/developers
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_WEBHOOK_SECRET=

# --- URLs públicas (para webhooks y redirect URLs) ---
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
